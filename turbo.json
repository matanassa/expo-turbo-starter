{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "ANDROID_PACKAGE",
    "APP_NAME",
    "APP_SCHEME",
    "APP_SLUG",
    "EAS_PROJECT_ID",
    "IOS_BUNDLE_IDENTIFIER"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "test:watch": {
      "cache": false,
      "persistent": true
    },
    "test:coverage": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    }
  }
}
